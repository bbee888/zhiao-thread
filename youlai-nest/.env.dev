# =========================
# 应用基础配置
# =========================
NODE_ENV=dev
APP_PORT=8000
SESSION_TYPE=jwt
REDIS_ENABLED=false

# =========================
# MySQL 数据库配置（TypeORM）
# =========================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=youlai_admin
TYPEORM_LOGGING=true

# =========================
# Redis 配置
# =========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=7
REDIS_PASSWORD=

# =========================
# JWT 认证配置
# =========================
JWT_SECRET_KEY=dev-secret-key-please-change-0123456789abcdef0123456789abcdef
JWT_EXPIRES_IN=7200
JWT_ISSUER=youlai-nest

# =========================
# OSS / 文件存储
# =========================
OSS_TYPE=local
OSS_MINIO_ENDPOINT=http://localhost:9000
OSS_MINIO_ACCESS_KEY=minioadmin
OSS_MINIO_SECRET_KEY=minioadmin
OSS_MINIO_BUCKET=default
OSS_MINIO_CUSTOM_DOMAIN=

OSS_ALIYUN_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_ALIYUN_ACCESS_KEY_ID=
OSS_ALIYUN_ACCESS_KEY_SECRET=
OSS_ALIYUN_BUCKET=default

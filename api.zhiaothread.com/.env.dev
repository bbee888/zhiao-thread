# =========================
# 应用基础配置
# =========================

# 运行环境：dev / prod / test 
NODE_ENV=dev

# Nest 应用监听端口（统一后端端口：8000）
APP_PORT=8000

# 会话类型：jwt | redis-token
SESSION_TYPE=jwt
# 禁用Redis，使用内存存储
REDIS_ENABLED=false


# =========================
# MySQL 数据库配置（TypeORM）
# =========================

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DB=youlai_admin

# TypeORM SQL 日志输出
# - 开发环境：true（方便排查 SQL）
# - 生产环境：false（避免日志过大）
TYPEORM_LOGGING=true


# =========================
# Redis 配置
# =========================
# 用于缓存、会话、验证码等
# 暂时禁用Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=7
# 无密码可以留空
REDIS_PASSWORD=


# =========================
# JWT 认证配置
# =========================
# 对应 src/config/jwt.config.ts 中的 JWT_SECRET_KEY / JWT_EXPIRES_IN / JWT_ISSUER

# JWT密钥(HS256算法至少32字符)
JWT_SECRET_KEY=SecretKey012345678901234567890123456789012345678901234567890123456789

# 访问 Token 过期时间（单位：秒，例如 7200 表示 2 小时）
JWT_EXPIRES_IN=7200

# Token 签发方标识，用于区分不同系统
JWT_ISSUER=youlai-nest


# =========================
# OSS / 文件存储（MinIO / 阿里云 / 本地）
# =========================

# OSS 类型：aliyun | minio | local
OSS_TYPE=local


# 本地存储路径（仅在 OSS_TYPE=local 时生效）
# 支持相对路径（相对于项目根目录）和绝对路径
# 相对路径示例：data/oss/ 或 ./data/oss/
# 绝对路径示例：/var/www/data/oss/
OSS_LOCAL_STORAGE_PATH=/data/oss/
